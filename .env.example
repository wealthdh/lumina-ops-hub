# ── Supabase ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # server-side only

# ── LuminaPulse MT5 Bridge ──────────────────────────────────
VITE_MT5_BRIDGE_URL=http://localhost:8080               # local MT5 REST bridge
VITE_MT5_ACCOUNT_ID=your_mt5_account_id
VITE_MT5_API_KEY=your_luminapulse_api_key              # from existing LP config

# ── Stripe ──────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...                          # server-side only

# ── Plaid ───────────────────────────────────────────────────
VITE_PLAID_ENV=production                              # sandbox | development | production
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret

# ── WalletConnect ───────────────────────────────────────────
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_id

# ── Polymarket ──────────────────────────────────────────────
VITE_POLYMARKET_API_URL=https://clob.polymarket.com
VITE_POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# ── Claude / Anthropic ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                           # server-side only

# ── Arcads / Kling (UGC) ────────────────────────────────────
VITE_ARCADS_API_KEY=your_arcads_key
# Kling AI — server-side only (used by api/kling.js)
KLING_ACCESS_KEY=your_kling_access_key
KLING_SECRET_KEY=your_kling_secret_key
# Optional: override Kling base URL (default: https://api.klingai.com)
# KLING_API_BASE=https://api.klingai.com

# ── App ─────────────────────────────────────────────────────
VITE_APP_URL=https://your-vercel-app.vercel.app
